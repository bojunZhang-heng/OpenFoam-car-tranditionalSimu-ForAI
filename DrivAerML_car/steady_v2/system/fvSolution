FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
solvers
{
    p
    {
        solver          GAMG;
        smoother        DICGaussSeidel;
        tolerance       1e-7;
        relTol          0.01;
        maxIter         25;

        nPreSweeps      0;
        nPostSweeps     2;
        nFinestSweeps   2;

        cacheAgglomeration true;
        nCellsInCoarsestLevel 20;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    }

    Phi
    {
        $p;
    }

    // velocity and main turbulence variables
    "(U|k|omega|epsilon)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.1;
        nSweeps         1;
        maxIter         25;
    }

    // optional: keep epsilon if used by model (if using kOmega, epsilon may be unused)
    "epsilon"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.1;
    }
}

SIMPLE
{
    // non-orthogonality up to ~70 in your mesh -> need correctors
    nNonOrthogonalCorrectors 2;
    consistent yes;
}

potentialFlow
{
    nNonOrthogonalCorrectors 10;
}

relaxationFactors
{
    fields
    {
        // pressure field relaxed more gently via fields
        p                       0.20;
    }

    equations
    {
        U                       0.30;
        k                       0.20;
        omega                   0.20;
        // epsilon if present
        "(epsilon).*"           0.20;
    }
}

cache
{
    grad(U);
}

