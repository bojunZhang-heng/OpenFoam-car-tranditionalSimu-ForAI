FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains  60;

method              hierarchical;      
//scotch hierarchical

simpleCoeffs
{
    n               (10 4 3);
}

hierarchicalCoeffs
{
    n               (5 4 3);
    order           xyz;
}

constraints
{
    patches
    {
        type  preservePatches;
        patches     ("AMI.*");
    }
}

manualCoeffs
{
    dataFile        "cellDecomposition";
}


